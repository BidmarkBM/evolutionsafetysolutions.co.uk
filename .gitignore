
# ignore everything in the "wp-content" directory, except:
# "mu-plugins", "plugins", "themes" directory
wp-content/*
!wp-content/mu-plugins/
!wp-content/plugins/
!wp-content/themes/

# ignore these plugins
wp-content/plugins/hello.php
wp-content/plugins/brozzme-db-prefix-change.php
wp-content/plugins/relative-url.php
wp-content/plugins/show-current-template.php
wp-content/plugins/acf-better-search/



# ignore specific themes
wp-content/themes/twenty*/

# ignore Wordpress config
wp-config.php

# ignore Wordpress install.sh
wp-install.sh

# ignore node dependency directories
node_modules/
wp-content/themes/bidmark-dev/vendor/

# ignore log files and databases
*.log
*.sql
*.sqlite

.htaccess
