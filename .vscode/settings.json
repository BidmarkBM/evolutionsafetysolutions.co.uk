	"editor.tokenColorCustomizations": {
		"comments": "#6C508E",
		"functions": "#B066FF",
		"keywords": "#F0A4FF",
		"numbers": "#FFB3FF",
		"strings": "#E5D8FF",
		"types": "#D26CFF",
		"variables": "#F5EEFF",
		"textMateRules": [
			{
				"name": "Comments",
				"scope": ["comment", "punctuation.definition.comment"],
				"settings": {
					"foreground": "#6C508E",
					"fontStyle": "italic"
				}
			},
			{
				"name": "Doc Comments",
				"scope": [
					"comment.block.documentation",
					"comment.documentation"
				],
				"settings": {
					"foreground": "#7A5A9F",
					"fontStyle": "italic"
				}
			},
			{
				"name": "Keywords & Control Flow",
				"scope": [
					"keyword",
					"keyword.control",
					"keyword.control.conditional",
					"keyword.control.loop",
					"keyword.control.switch",
					"keyword.control.import",
					"keyword.control.export",
					"keyword.control.from",
					"keyword.operator.new",
					"keyword.control.trycatch",
					"keyword.control.return"
				],
				"settings": {
					"foreground": "#F0A4FF",
					"fontStyle": "bold"
				}
			},
			{
				"name": "Storage Types & Modifiers",
				"scope": [
					"storage",
					"storage.type",
					"storage.modifier",
					"storage.type.class",
					"storage.type.function",
					"storage.type.var",
					"storage.type.primitive"
				],
				"settings": {
					"foreground": "#D26CFF",
					"fontStyle": ""
				}
			},
			{
				"name": "Operators & Logical",
				"scope": [
					"keyword.operator",
					"keyword.operator.arithmetic",
					"keyword.operator.assignment",
					"keyword.operator.comparison",
					"keyword.operator.bitwise",
					"keyword.operator.logical",
					"keyword.operator.ternary"
				],
				"settings": {
					"foreground": "#C57AFF",
					"fontStyle": ""
				}
			},
			{
				"name": "Constants Numeric",
				"scope": [
					"constant.numeric",
					"constant.integer",
					"constant.float",
					"constant.hex",
					"constant.octal",
					"constant.binary"
				],
				"settings": {
					"foreground": "#FFB3FF",
					"fontStyle": ""
				}
			},
			{
				"name": "Constants Language & Boolean",
				"scope": [
					"constant.language",
					"constant.language.boolean",
					"constant.language.null",
					"constant.language.undefined"
				],
				"settings": {
					"foreground": "#F0A4FF",
					"fontStyle": "italic"
				}
			},
			{
				"name": "Other Constants (Colors, etc.)",
				"scope": [
					"constant.other.color",
					"support.constant",
					"variable.other.constant"
				],
				"settings": {
					"foreground": "#F0A4FF",
					"fontStyle": ""
				}
			},
			{
				"name": "Strings",
				"scope": [
					"string",
					"string.quoted",
					"string.quoted.single",
					"string.quoted.double"
				],
				"settings": {
					"foreground": "#E5D8FF",
					"fontStyle": ""
				}
			},
			{
				"name": "Template Strings",
				"scope": [
					"string.template",
					"string.quoted.template",
					"punctuation.definition.template-expression.begin",
					"punctuation.definition.template-expression.end"
				],
				"settings": {
					"foreground": "#E5D8FF",
					"fontStyle": ""
				}
			},
			{
				"name": "Regular Expressions",
				"scope": [
					"string.regexp",
					"constant.other.character-class.set.regexp",
					"constant.character.escape",
					"keyword.control.anchor.regexp"
				],
				"settings": {
					"foreground": "#C57AFF",
					"fontStyle": ""
				}
			},
			{
				"name": "Interpolated Expression in Template String",
				"scope": [
					"meta.template.expression",
					"punctuation.definition.template-expression"
				],
				"settings": {
					"foreground": "#B066FF",
					"fontStyle": ""
				}
			},
			{
				"name": "Function Names",
				"scope": [
