	"editor.tokenColorCustomizations": {
		"comments": "#6e5a9c",
		"functions": "#00f0ff",
		"keywords": "#b82bf2",
		"numbers": "#f2e82b",
		"strings": "#00ff9d",
		"types": "#0088ff",
		"variables": "#e0d8f0",
		"textMateRules": [
			{
				"scope": [
					"comment",
					"punctuation.definition.comment",
					"string.comment"
				],
				"settings": {
					"foreground": "#6e5a9c",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"keyword",
					"keyword.control",
					"keyword.operator.new",
					"keyword.operator.expression",
					"keyword.operator.logical",
					"keyword.operator.delete",
					"punctuation.definition.keyword"
				],
				"settings": {
					"foreground": "#b82bf2",
					"fontStyle": "italic"
				}
			},
			{
				"scope": ["storage", "storage.type", "storage.modifier"],
				"settings": {
					"foreground": "#b82bf2",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"constant.language",
					"constant.numeric",
					"constant.character.escape"
				],
				"settings": {
					"foreground": "#f2e82b"
				}
			},
			{
				"scope": [
					"string",
					"string.template",
					"string.quoted",
					"string.regexp",
					"punctuation.definition.string"
				],
				"settings": {
					"foreground": "#00ff9d"
				}
			},
			{
				"scope": [
					"entity.name.function",
					"support.function",
					"meta.function-call"
				],
				"settings": {
					"foreground": "#00f0ff",
					"fontStyle": "bold"
				}
			},
			{
				"scope": [
					"entity.name.class",
					"entity.name.type",
					"entity.other.inherited-class",
					"support.class",
					"support.type"
				],
				"settings": {
					"foreground": "#0088ff",
					"fontStyle": "bold"
				}
			},
			{
				"scope": [
					"variable",
					"variable.other",
					"variable.language",
					"support.variable",
					"meta.object-literal.key",
					"meta.property.object"
				],
				"settings": {
					"foreground": "#e0d8f0"
				}
			},
			{
				"scope": ["variable.parameter", "meta.parameters"],
				"settings": {
					"foreground": "#a89fc4",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"variable.other.constant",
					"variable.other.enummember"
				],
				"settings": {
					"foreground": "#f2e82b",
					"fontStyle": "bold"
				}
			},
			{
				"scope": ["entity.name.tag", "punctuation.definition.tag"],
				"settings": {
					"foreground": "#b82bf2"
				}
			},
			{
				"scope": ["entity.other.attribute-name", "meta.tag.attributes"],
				"settings": {
					"foreground": "#00f0ff",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"meta.selector",
					"entity.other.attribute-name.class.css",
					"entity.other.attribute-name.id.css",
					"entity.name.tag.css"
				],
				"settings": {
					"foreground": "#0088ff"
				}
			},
			{
				"scope": [
					"support.type.property-name.css",
					"meta.property-name.css"
				],
				"settings": {
					"foreground": "#00f0ff"
				}
			},
			{
				"scope": [
					"meta.property-value.css",
					"support.constant.property-value.css",
					"constant.numeric.css",
					"keyword.other.unit.css"
				],
				"settings": {
					"foreground": "#f2e82b"
				}
			},
			{
				"scope": [
					"entity.other.attribute-name.pseudo-class.css",
					"entity.other.attribute-name.pseudo-element.css"
				],
				"settings": {
					"foreground": "#b82bf2",
					"fontStyle": "italic"
				}
			},
			{
				"scope": [
					"punctuation.section.embedded.begin.php",
					"punctuation.section.embedded.end.php"
				],
				"settings": {
					"foreground": "#b82bf2",
					"fontStyle": "bold"
				}
			},
			{
				"scope": ["markup.heading", "entity.name.section"],
				"settings": {
					"foreground": "#00f0ff",
					"fontStyle": "bold"
				}
			},
			{
				"scope": "markup.bold",
				"settings": {
					"foreground": "#e0d8f0",
					"fontStyle": "bold"
				}
			},
			{
				"scope": "markup.italic",
				"settings": {
					"foreground": "#e0d8f0",
					"fontStyle": "italic"
				}
			},
			{
				"scope": "markup.inline.raw",
				"settings": {
					"foreground": "#00ff9d"
				}
			},
			{
				"scope": "markup.underline.link",
				"settings": {
					"foreground": "#0088ff",
					"fontStyle": "underline"
				}
			},
			{
				"scope": ["invalid", "invalid.illegal", "invalid.deprecated"],
				"settings": {
					"foreground": "#ff003c",
					"fontStyle": "bold underline"
				}
			}
		]
	}
}
